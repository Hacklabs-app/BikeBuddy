{
  "extends": ["@commitlint/config-conventional"],
  "ignores": [
    "^Potential fix",
    "^Merge",
    "^Revert"
  ],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "chore", "docs", "refactor", "test", "style", "ci"]
    ],
    "header-max-length": [2, "always", 100]
  }
}
